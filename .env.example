# Voix IA (optionnel). Sans cle, PULSE utilise la voix locale (genVoix).
# Cle serveur OpenRouter : https://openrouter.ai/keys
# En prod Vercel, definir OPENROUTER_KEY dans les variables d'environnement.
OPENROUTER_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Voix audio naturelle (optionnel). Sans cle, fallback sur la voix navigateur.
OPENAI_API_KEY=
OPENAI_ASK_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=cedar
